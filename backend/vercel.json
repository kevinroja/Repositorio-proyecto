{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["../frontend/**"]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "app.js" },
    { "src": "/css/(.*)", "dest": "app.js" },
    { "src": "/js/(.*)", "dest": "app.js" },
    { "src": "/img/(.*)", "dest": "app.js" },
    { "src": "/pages/(.*)", "dest": "app.js" },
    { "src": "/favicon.ico", "dest": "app.js" },
    { "src": "/", "dest": "app.js" },
    { "src": "/(.*)", "dest": "app.js" }
  ]
}
